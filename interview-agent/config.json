{
  "github_username": "Rcardo",
  "agent_name": "技术面试助手",
  "agent_description": "基于我的 GitHub 开源项目，回答技术面试问题",
  "language": "zh-CN",
  "repos": {
    "mode": "all_public",
    "exclude": ["dotfiles", "tutorial-project"],
    "include": []
  },
  "model": {
    "provider": "deepseek",
    "primary": "deepseek-chat",
    "fallback": "deepseek-chat"
  },
  "index_storage": {
    "repository_owner": "XRX193",
    "repository_name": "An-Agent-For-Interview",
    "branch": "main"
  },
  "ui": {
    "primary_color": "#1a1a2e",
    "accent_color": "#0f3460",
    "candidate_name": "向荣鑫",
    "candidate_title": "软件工程师"
  },
  "limits": {
    "max_history_rounds": 10,
    "rate_limit_per_minute": 20,
    "max_question_length": 2000,
    "retrieve_top_k": 5
  },
  "security": {
    "allowed_origins": [
      "https://xrx193.github.io",
      "http://localhost:5173",
      "http://127.0.0.1:5173"
    ]
  }
}
